// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// 1.1 ENUMS
enum UserRole {
  AGENCY
  ADMIN
  SUPER_ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LedgerType {
  CREDIT
  DEBIT
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

// 1.2 USERS & AGENCIES
model Agency {
  id                  String             @id @default(uuid())
  name                String
  type                String             @default("Retail")
  email               String             @unique
  status              Boolean            @default(true)
  verification_status VerificationStatus @default(UNVERIFIED)
  created_at          DateTime           @default(now())
  updated_at          DateTime           @default(now()) @updatedAt

  users               User[]
  ledger              WalletLedger[]
  deposits            Deposit[]
  bookings            Booking[]
  documents           VerificationDocument[]
  // tours removed as per authoritative schema (Tours are global)
}

model User {
  id            String    @id @default(uuid())
  agency_id     String?
  agency        Agency?   @relation(fields: [agency_id], references: [id])
  email         String    @unique
  password_hash String
  role          UserRole
  last_login    DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt

  // System tables
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  reviewed_deposits Deposit[]
  
  // Auth extra
  resetToken          String?
  resetTokenExpiry    DateTime?
}

// 1.3 WALLET & LEDGER
model WalletLedger {
  id              String     @id @default(uuid())
  agency_id       String
  agency          Agency     @relation(fields: [agency_id], references: [id])
  type            LedgerType
  amount          Decimal    @db.Decimal(12, 2)
  reference_type  String
  reference_id    String?
  created_at      DateTime   @default(now())

  @@index([agency_id])
  @@index([agency_id, created_at])
}

// 1.4 DEPOSITS (BANK TRANSFER)
model Deposit {
  id              String        @id @default(uuid())
  agency_id       String
  agency          Agency        @relation(fields: [agency_id], references: [id])
  amount          Decimal       @db.Decimal(12, 2)
  bank_reference  String
  proof_url       String?
  status          DepositStatus @default(PENDING)
  reviewed_by     String?
  reviewer        User?         @relation(fields: [reviewed_by], references: [id])
  reviewed_at     DateTime?
  created_at      DateTime      @default(now())

  @@index([agency_id, status])
}

// 1.5 TOURS & BOOKINGS
model Tour {
  id        String   @id @default(uuid())
  name      String
  duration  String?
  price     Decimal  @db.Decimal(12, 2)
  active    Boolean  @default(true)

  bookings  Booking[]
}

model Booking {
  id           String        @id @default(uuid())
  agency_id    String
  agency       Agency        @relation(fields: [agency_id], references: [id])
  tour_id      String
  tour         Tour          @relation(fields: [tour_id], references: [id])
  travel_date  DateTime      @db.Date
  amount       Decimal       @db.Decimal(12, 2)
  status       BookingStatus @default(CONFIRMED)
  created_at   DateTime      @default(now())

  @@index([agency_id, created_at])
}

// 1.6 VERIFICATION DOCUMENTS
model VerificationDocument {
  id          String   @id @default(uuid())
  agency_id   String
  agency      Agency   @relation(fields: [agency_id], references: [id])
  doc_type    String
  file_url    String
  created_at  DateTime @default(now())
}

// 1.7 AUDIT LOGS (IMMUTABLE)
model AuditLog {
  id          String   @id @default(uuid())
  actor_id    String?
  actor       User?    @relation(fields: [actor_id], references: [id])
  action      String
  entity      String
  entity_id   String?
  ip_address  String?
  created_at  DateTime @default(now())

  @@index([created_at])
}

// SYSTEM / AUTH (Not in Business Logic Schema but required for functionality)
model RefreshToken {
  id          String   @id @default(uuid())
  token       String   @unique
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at  DateTime
  created_at  DateTime @default(now())
  revoked     Boolean  @default(false)
}

