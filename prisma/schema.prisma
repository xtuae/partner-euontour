// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// 1.1 ENUMS
enum UserRole {
  AGENCY
  ADMIN
  SUPER_ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum DepositStatus {
  SUBMITTED
  PENDING
  PENDING_ADMIN
  PENDING_SUPER_ADMIN
  APPROVED
  REJECTED
}

enum LedgerType {
  CREDIT
  DEBIT
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  CANCELLED_BY_ADMIN
}

enum AgencyStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  ACTIVE
  SUSPENDED
  BLOCKED
}

// 1.2 USERS & AGENCIES
model Agency {
  id                  String             @id @default(uuid())
  name                String
  type                String             @default("Retail")
  email               String             @unique
  // status              Boolean            @default(true) // Removed in favor of Enum
  status              AgencyStatus       @default(ACTIVE)
  wallet_locked       Boolean            @default(false)
  booking_locked      Boolean            @default(false)
  verification_status VerificationStatus @default(UNVERIFIED)
  wallet_balance      Decimal            @default(0.00) @db.Decimal(12, 2)
  created_at          DateTime           @default(now())
  updated_at          DateTime           @default(now()) @updatedAt

  users               User[]
  ledger              WalletLedger[]
  deposits            Deposit[]
  bookings            Booking[]
  documents           VerificationDocument[]
  owner_kyc           AgencyOwnerKyc[]
  // tours removed as per authoritative schema (Tours are global)
  agency_tours AgencyTour[]
  notifications       Notification[]
}

model User {
  id            String    @id @default(uuid())
  agency_id     String?
  agency        Agency?   @relation(fields: [agency_id], references: [id])
  name          String?
  email         String    @unique
  password_hash String
  role          UserRole
  active        Boolean   @default(true)
  last_login    DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt

  // System tables
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  reviewed_deposits Deposit[]
  notifications      Notification[]
  
  // Auth extra

  // Auth extra
  resetToken          String?
  resetTokenExpiry    DateTime?
  
  // Email Verification
  email_verified            Boolean   @default(false)
  verification_token        String?
  verification_token_expiry DateTime?
}

// 1.3 WALLET & LEDGER
model WalletLedger {
  id              String     @id @default(uuid())
  agency_id       String
  agency          Agency     @relation(fields: [agency_id], references: [id])
  type            LedgerType
  amount          Decimal    @db.Decimal(12, 2)
  reference_type  String
  reference_id    String?
  description     String   @default("")
  created_at      DateTime   @default(now())

  @@index([agency_id])
  @@index([agency_id, created_at])
}

// 1.4 DEPOSITS (BANK TRANSFER)
model Deposit {
  id              String        @id @default(uuid())
  agency_id       String
  agency          Agency        @relation(fields: [agency_id], references: [id])
  amount          Decimal       @db.Decimal(12, 2)
  bank_reference  String
  proof_url       String?
  thumbnail_url   String?
  status          DepositStatus @default(PENDING_ADMIN)
  reviewed_by     String?
  reviewer        User?         @relation(fields: [reviewed_by], references: [id])
  reviewed_at     DateTime?
  created_at      DateTime      @default(now())

  @@index([agency_id, status])
}

// 1.5 TOURS & BOOKINGS
model Tour {
  id         String   @id @default(uuid())
  wp_tour_id Int      @unique
  name       String
  duration         String?
  price            Decimal  @db.Decimal(12, 2)
  agency_net_price Decimal  @default(0.00) @db.Decimal(12, 2)
  active           Boolean  @default(true)
  image_url  String?
  deletedAt  DateTime?

  bookings  Booking[]
  agency_tours AgencyTour[]
}

model AgencyTour {
  id        String   @id @default(uuid())
  agencyId  String
  tourId    String
  sortOrder Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id])
  tour   Tour   @relation(fields: [tourId], references: [id])

  @@unique([agencyId, tourId])
}

model Booking {
  id           String        @id @default(uuid())
  agency_id    String
  agency       Agency        @relation(fields: [agency_id], references: [id])
  tour_id      String
  tour         Tour          @relation(fields: [tour_id], references: [id])
  travel_date  DateTime      @db.Date
  amount       Decimal       @db.Decimal(12, 2)
  status       BookingStatus @default(CONFIRMED)
  created_at   DateTime      @default(now())

  @@index([agency_id, created_at])
}

// 1.6 VERIFICATION DOCUMENTS (Business)
model VerificationDocument {
  id          String   @id @default(uuid())
  agency_id   String
  agency      Agency   @relation(fields: [agency_id], references: [id])
  doc_type    String
  file_url    String
  thumbnail_url String?
  created_at  DateTime @default(now())
}

// 1.8 AGENCY OWNER KYC
model AgencyOwnerKyc {
  id              String   @id @default(uuid())
  agencyId        String   
  fullName        String
  nationality     String
  idType          String
  idNumber        String
  idExpiry        DateTime
  idFrontUrl      String

  idFrontThumbnail String?
  idBackUrl       String?
  idBackThumbnail String?
  selfieUrl       String?
  selfieThumbnail String?
  status          String   @default("PENDING") // PENDING | VERIFIED | REJECTED
  rejectionReason String?
  
  businessOcrText String?  @db.Text
  ownerIdOcrText  String?  @db.Text
  ocrStatus       String?  // PENDING | COMPLETED | FAILED
  ocrCompletedAt  DateTime?

  createdAt       DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id])
  
  @@index([agencyId])
}

// 1.7 AUDIT LOGS (IMMUTABLE)
model AuditLog {
  id          String   @id @default(uuid())
  actor_id    String?
  actor       User?    @relation(fields: [actor_id], references: [id])
  action      String
  entity      String
  entity_id   String?
  agency_id   String?
  metadata    Json?
  ip_address  String?
  created_at  DateTime @default(now())

  @@index([created_at])
}

// SYSTEM / AUTH (Not in Business Logic Schema but required for functionality)
model RefreshToken {
  id          String   @id @default(uuid())
  token       String   @unique
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at  DateTime
  created_at  DateTime @default(now())
  revoked     Boolean  @default(false)
}

model SystemSettings {
    key         String   @id
    value       String
    updated_at  DateTime @updatedAt
    updated_by  String?
}

// 1.9 NOTIFICATIONS
model Notification {
  id        String   @id @default(uuid())
  agencyId  String?  // Relation to Agency
  agency    Agency?  @relation(fields: [agencyId], references: [id])
  userId    String?  // Relation to User (optional specific target)
  user      User?    @relation(fields: [userId], references: [id])
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([agencyId])
  @@index([userId])
}
